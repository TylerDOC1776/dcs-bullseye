DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here
ORCHESTRATOR_URL=http://localhost:8888
ORCHESTRATOR_API_KEY=change-me
BOT_CHANNEL_ID=          # optional — restrict slash commands to one channel
OPERATOR_ROLE=DCS Operator
EVENTS_CHANNEL_ID=       # optional — SSE notifications; defaults to BOT_CHANNEL_ID
STATUS_CHANNEL_ID=       # optional — channel for the pinned live-status embed
EXTERNAL_SERVERS=[]      # optional — JSON array: [{"name":"East Coast BBQ","ip":"1.2.3.4","port":10308}]
AUTO_RESTART_EXCLUDE=    # optional — comma-separated instance names exempt from keepalive auto-start (e.g. TexasBBQ)
